.thinking-chip-row {
  justify-content: center;
}

.thinking-chip {
  min-width: 170rpx;
}

.thinking-timer {
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.timer-clock {
  font-size: 96rpx;
  font-weight: 700;
}

.thinking-tip {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.thinking-method {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(247, 250, 255, 0.88);
  box-shadow: inset 0 0 0 2rpx rgba(91, 111, 255, 0.08);
}

.thinking-tip-label {
  color: #1d2240;
  font-weight: 800;
  font-size: 26rpx;
}
