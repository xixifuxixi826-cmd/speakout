.top-row {
  margin-bottom: 24rpx;
}

.training-rule {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.training-chip-row {
  margin-bottom: 20rpx;
}

.training-chip-row--center {
  justify-content: center;
}

.training-selected-chip {
  min-width: 170rpx;
}

.training-matrix {
  padding: 16rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.matrix-card {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 12rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    inset 0 0 0 2rpx rgba(90, 123, 255, 0.1),
    0 12rpx 24rpx rgba(67, 89, 184, 0.08);
  transition: transform 240ms ease, box-shadow 240ms ease, background 240ms ease;
  transform-style: preserve-3d;
}

.matrix-card--selected {
  background: linear-gradient(145deg, #baff6d 0%, #6ff8c1 100%);
  color: #18224d;
  box-shadow:
    inset 0 0 0 2rpx rgba(47, 149, 102, 0.12),
    0 20rpx 32rpx rgba(70, 205, 141, 0.24);
}

.matrix-card--used {
  background: linear-gradient(145deg, #edf0f9 0%, #dde2f0 100%);
  color: #8d94b0;
}

.matrix-card--hidden:active {
  transform: scale(0.97);
}

.matrix-card--flipped {
  animation: card-flip-in 240ms ease;
}

.matrix-hidden {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #ff7a93 0%, #5d7dff 100%);
}

.matrix-hidden-mark {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
}

.matrix-body {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  animation: card-content-in 200ms ease;
}

.matrix-word {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
}

@keyframes card-flip-in {
  0% {
    transform: rotateY(88deg) scale(0.94);
    opacity: 0.35;
  }

  100% {
    transform: rotateY(0deg) scale(1);
    opacity: 1;
  }
}

@keyframes card-content-in {
  0% {
    transform: translateY(10rpx);
    opacity: 0;
  }

  100% {
    transform: translateY(0);
    opacity: 1;
  }
}
