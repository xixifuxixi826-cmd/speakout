.speaking-editor {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.speaking-focus {
  padding: 22rpx 22rpx 8rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(247, 251, 255, 0.96));
  box-shadow: inset 0 0 0 2rpx rgba(91, 111, 255, 0.08);
}

.speaking-focus__label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #6a7197;
  text-align: center;
}

.speaking-chip-row {
  justify-content: center;
}

.speaking-chip-row--spotlight {
  gap: 18rpx;
}

.speaking-chip {
  min-width: 170rpx;
}

.speaking-chip--spotlight {
  min-width: 190rpx;
  min-height: 78rpx;
  font-size: 28rpx;
}

.speaking-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.speaking-head-copy {
  flex: 1;
}

.speaking-action-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.speaking-action-row--secondary {
  justify-content: center;
}

.speaking-action {
  flex: 1;
  min-height: 76rpx;
  font-size: 26rpx;
}

.speaking-action--primary {
  flex: 1.2;
}

.speaking-action--wide {
  width: 100%;
}

.transcript-board {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(243, 246, 255, 0.95), rgba(255, 255, 255, 0.96));
  box-shadow: inset 0 0 0 2rpx rgba(91, 111, 255, 0.08);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.transcript-text {
  white-space: pre-wrap;
  color: #2c345e;
}

.transcript-input {
  width: 100%;
  min-height: 260rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #2c345e;
}
